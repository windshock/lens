{
  "manifest_version": 3,
  "name": "ScamGuard AI",
  "version": "0.1.32",
  "description": "Chrome 내장 Gemini Nano 기반 100% 온디바이스(Zero-Data) 피싱 및 스캠 탐지기.",
  "minimum_chrome_version": "138",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "현재 페이지 피싱 검사",
    "default_popup": "popup.html"
  },
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting",
    "storage",
    "notifications",
    "offscreen",
    "downloads",
    "activeTab",
    "bookmarks",
    "history",
    "topSites"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "click_guard.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warning.html",
        "warning.css",
        "warning.js",
        "verdict.html",
        "verdict.js",
        "i18n.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
