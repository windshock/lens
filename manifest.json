{
  "manifest_version": 3,
  "name": "Windshock Lens",
  "version": "0.2.2",
  "description": "Private, on-device scam and phishing analysis for your browser. Chrome built-in Gemini Nano + deterministic security rules.",
  "minimum_chrome_version": "138",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Windshock Lens — scan this page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/action-16.png",
      "32": "icons/action-32.png",
      "48": "icons/action-48.png",
      "128": "icons/action-128.png"
    }
  },
  "icons": {
    "16": "icons/action-16.png",
    "32": "icons/action-32.png",
    "48": "icons/action-48.png",
    "128": "icons/action-128.png"
  },
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting",
    "storage",
    "notifications",
    "offscreen",
    "downloads",
    "activeTab",
    "bookmarks",
    "history",
    "topSites"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "click_guard.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warning.html",
        "warning.css",
        "warning.js",
        "verdict.html",
        "verdict.js",
        "i18n.js",
        "compat-check.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
